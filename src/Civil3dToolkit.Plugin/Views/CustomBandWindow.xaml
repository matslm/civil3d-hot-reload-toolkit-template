<Window x:Class="Civil3dToolkit.Plugin.Views.CustomBandWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xml:lang="en-US"
        Title="Custom Band MTEXT" Height="380" Width="400"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="120"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Text="Values:" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,0,10"/>
        <TextBox Text="{Binding ValuesText, UpdateSourceTrigger=PropertyChanged}" Grid.Row="0" Grid.Column="1" Height="25" Margin="0,0,0,10"/>

        <TextBlock Text="Delimiter:" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,0,10"/>
        <TextBox Text="{Binding Delimiter, UpdateSourceTrigger=PropertyChanged}" Grid.Row="1" Grid.Column="1" Height="25" Margin="0,0,0,10"/>

        <TextBlock Text="Layer:" Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,0,10"/>
        <ComboBox ItemsSource="{Binding AvailableLayers}" SelectedItem="{Binding SelectedLayer}" Grid.Row="2" Grid.Column="1" Height="25" Margin="0,0,0,10"/>

        <TextBlock Text="Text Style:" Grid.Row="3" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,0,10"/>
        <ComboBox ItemsSource="{Binding AvailableTextStyles}" SelectedItem="{Binding SelectedTextStyle}" Grid.Row="3" Grid.Column="1" Height="25" Margin="0,0,0,10"/>

        <TextBlock Text="Text Size:" Grid.Row="4" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,0,10"/>
        <TextBox Text="{Binding TextSize, UpdateSourceTrigger=PropertyChanged}" Grid.Row="4" Grid.Column="1" Height="25" Margin="0,0,0,10"/>

        <TextBlock Text="Background Mask:" Grid.Row="5" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,0,10"/>
        <CheckBox IsChecked="{Binding UseBackgroundMask}" Grid.Row="5" Grid.Column="1" VerticalAlignment="Center" Margin="0,0,0,10"/>

        <Button Content="Insert Texts" Command="{Binding ExecuteCommand}" Grid.Row="9" Grid.Column="0" Grid.ColumnSpan="2" Height="35" Background="#FF007ACC" Foreground="White" FontWeight="Bold"/>
    </Grid>
</Window>